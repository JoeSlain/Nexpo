{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\" || tool == \"MultiEdit\"",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-code-simplifier.sh",
            "timeout": 120
          }
        ],
        "description": "Run the code-simplifier agent after each file modification"
      }
    ]
  }
}
